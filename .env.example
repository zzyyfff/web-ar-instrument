# web-ar-instrument — configuration reference. NO SECRETS in this file or in git.
#
# The backend needs the values below. Set them as Pages environment variables /
# bindings in your Cloudflare dashboard (Production + Preview), or in a local
# untracked `.dev.vars` for `wrangler pages dev`. None of these are credentials.

# --- R2 storage (binding, not a value) ---
# Bind your bucket as RECORDINGS in the Pages project (see wrangler.toml). The
# bucket is reachable only through the Access-gated /api functions.

# --- Cloudflare Access (Zero Trust) ---
# Gate the whole deployment to your identity, and let the functions verify the
# Access JWT as defense in depth.
CF_ACCESS_TEAM_DOMAIN="https://YOUR-TEAM.cloudflareaccess.com"
CF_ACCESS_AUD="your-access-application-aud-tag"

# --- CORS ---
# Exact origin allowed on the data routes. NEVER "*".
ALLOWED_ORIGIN="https://your-deployment.example.com"

# --- Client build (optional) ---
# Set to "" so the calibrator uploads to the same-origin backend, or to a full
# backend base URL. Unset = no backend (client-only, local file download).
# VITE_BACKEND_BASE=""

# --- CI deploy (GitHub Actions secrets, NOT here) ---
# CLOUDFLARE_API_TOKEN  — scoped token (Pages: Edit). Set as a GitHub repo secret.
# CLOUDFLARE_ACCOUNT_ID — your account id. Set as a GitHub repo secret.
